<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="OtpView">

        <attr name="otpLength" format="integer"/>

        <attr name="cellType">
            <enum name="box" value="0"/>
            <enum name="circle" value="1"/>
            <enum name="line" value="2"/>
        </attr>

        <attr name="borderColor" format="color"/>
        <attr name="focusedBorderColor" format="color"/>
        <attr name="filledBorderColor" format="color"/>
        <attr name="errorBorderColor" format="color"/>

        <attr name="textColor" format="color"/>
        <attr name="textSize" format="dimension"/>

        <attr name="cornerRadius" format="dimension"/>
        <attr name="borderWidth" format="dimension"/>

    </declare-styleable>

</resources>